<?xml version="1.0" encoding="utf-8"?>
<com.princess.botblade.ui.common.WorkstationScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BotBlade"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="@color/botblade_baby_blue"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="28dp"
                android:text="Command Center"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="@color/botblade_hot_pink"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Point A → Z bot workstation"
            android:textColor="@color/botblade_on_surface_muted" />

        <com.princess.botblade.ui.dashboard.CommercialHomeDeckView
            android:id="@+id/commercial_home_deck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <com.princess.botblade.ui.dashboard.BotWorkstationDeckView
            android:id="@+id/bot_workstation_deck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:orientation="vertical"
            android:visibility="invisible">

            <TextView android:id="@+id/active_project_text" android:layout_width="match_parent" android:layout_height="1dp" />
            <TextView android:id="@+id/bot_status_text" android:layout_width="match_parent" android:layout_height="1dp" />
            <TextView android:id="@+id/dashboard_message_text" android:layout_width="match_parent" android:layout_height="1dp" />
            <Button android:id="@+id/refresh_status_button" android:layout_width="match_parent" android:layout_height="1dp" />
            <Button android:id="@+id/start_bot_button" android:layout_width="match_parent" android:layout_height="1dp" />
            <Button android:id="@+id/stop_bot_button" android:layout_width="match_parent" android:layout_height="1dp" />
            <Button android:id="@+id/restart_bot_button" android:layout_width="match_parent" android:layout_height="1dp" />
            <Button android:id="@+id/view_runtime_logs_button" android:layout_width="match_parent" android:layout_height="1dp" />
            <TextView android:id="@+id/runtime_terminal_text" android:layout_width="match_parent" android:layout_height="1dp" />
        </LinearLayout>
    </LinearLayout>
</com.princess.botblade.ui.common.WorkstationScrollView>