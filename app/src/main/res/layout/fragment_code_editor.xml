<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/botblade_black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.princess.botblade.ui.editor.ForgeEditorDeckView
            android:id="@+id/forge_editor_deck"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/editor_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/code_editor_empty_message"
            android:textColor="@color/botblade_on_surface_muted"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:id="@+id/detected_pack_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/botblade_panel"
            android:padding="12dp"
            android:textColor="@color/botblade_baby_blue"
            android:text="@string/detected_pack_placeholder" />

        <TextView
            android:id="@+id/missing_secrets_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@color/botblade_panel"
            android:padding="12dp"
            android:textColor="@color/botblade_hot_pink"
            android:text="@string/missing_secrets_placeholder" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/generate_project_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/generate_project" />

            <Button
                android:id="@+id/start_build_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/start_build" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/scan_project_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/scan_project" />

            <Button
                android:id="@+id/run_first_check_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/run_first_check" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/project_files"
            android:textColor="@color/botblade_hot_pink"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <LinearLayout
            android:id="@+id/file_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/selected_file_metadata"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/no_file_selected"
            android:textColor="@color/botblade_on_surface_muted" />

        <EditText
            android:id="@+id/file_content_editor"
            android:layout_width="match_parent"
            android:layout_height="360dp"
            android:layout_marginTop="8dp"
            android:background="@color/botblade_ink"
            android:gravity="top|start"
            android:hint="@string/file_content_hint"
            android:inputType="textMultiLine|textNoSuggestions"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:textColor="@color/botblade_on_surface"
            android:textColorHint="@color/botblade_on_surface_muted" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/save_file_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/save_file" />

            <Button
                android:id="@+id/revert_file_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/revert_file" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>