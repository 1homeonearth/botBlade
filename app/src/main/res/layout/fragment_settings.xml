<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/botblade_black">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/botblade_panel_raised"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/botblade_hot_pink"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Workstation Settings"
                    android:textColor="@color/botblade_baby_blue"
                    android:textAppearance="?attr/textAppearanceHeadlineMedium" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Project support center for backend connection, updates, GitHub, Vault, runtime defaults, diagnostics, and release readiness."
                    android:textColor="@color/botblade_on_surface_muted" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.princess.botblade.releases.AppUpgradePanelView
            android:id="@+id/app_upgrade_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Backend connection"
            android:textColor="@color/botblade_hot_pink"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <TextView
            android:id="@+id/api_settings_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/botblade_on_surface_muted"
            android:text="@string/backend_url_default_status" />

        <EditText
            android:id="@+id/backend_url_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/backend_url_hint"
            android:textColor="@color/botblade_on_surface"
            android:textColorHint="@color/botblade_on_surface_muted"
            android:inputType="textUri|textNoSuggestions" />

        <Button
            android:id="@+id/save_backend_url_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save_backend_url" />

        <Button
            android:id="@+id/test_backend_connection_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/test_backend_connection" />

        <Button
            android:id="@+id/share_startup_diagnostics_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/share_startup_diagnostics"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Runtime defaults"
            android:textColor="@color/botblade_hot_pink"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <TextView
            android:id="@+id/bot_token_masked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/botblade_on_surface"
            android:text="Bot token: Not set" />

        <Button
            android:id="@+id/change_bot_token_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Change legacy bot token" />

        <Button
            android:id="@+id/clear_bot_token_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear legacy bot token" />

        <Switch
            android:id="@+id/auto_start_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/botblade_on_surface"
            android:text="Start active bot automatically on device boot." />

        <TextView
            android:id="@+id/auto_start_disclaimer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/botblade_on_surface_muted"
            android:text="Autostart applies to the active project runtime after the backend and secrets are configured."
            android:visibility="gone" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/dynamic_color_switch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/botblade_on_surface"
            android:text="Use Material You colors (preview only; BotBlade dark readability stays enforced)" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="GitHub + release rail"
            android:textColor="@color/botblade_hot_pink"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <TextView
            android:id="@+id/github_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/botblade_on_surface_muted"
            android:text="@string/github_loading" />

        <EditText
            android:id="@+id/github_token_ref_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/github_token_ref_hint"
            android:textColor="@color/botblade_on_surface"
            android:textColorHint="@color/botblade_on_surface_muted"
            android:inputType="textNoSuggestions" />

        <Button
            android:id="@+id/connect_github_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/connect_github" />

        <EditText
            android:id="@+id/github_owner_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/github_owner_hint"
            android:textColor="@color/botblade_on_surface"
            android:textColorHint="@color/botblade_on_surface_muted"
            android:inputType="textNoSuggestions" />

        <EditText
            android:id="@+id/github_repo_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/github_repo_hint"
            android:textColor="@color/botblade_on_surface"
            android:textColorHint="@color/botblade_on_surface_muted"
            android:inputType="textNoSuggestions" />

        <EditText
            android:id="@+id/github_branch_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/github_branch_hint"
            android:textColor="@color/botblade_on_surface"
            android:textColorHint="@color/botblade_on_surface_muted"
            android:inputType="textNoSuggestions" />

        <Button
            android:id="@+id/link_github_repo_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/link_github_repo" />

        <Button
            android:id="@+id/create_github_workflow_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/create_github_workflow" />

        <Button
            android:id="@+id/push_github_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/push_github_disabled" />

        <TextView
            android:id="@+id/github_workflow_help_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/botblade_on_surface_muted"
            android:text="@string/github_workflow_help" />

        <Button
            android:id="@+id/copy_github_workflow_help_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/copy_workflow_help" />

        <TextView
            android:id="@+id/apk_downloads_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:autoLink="web"
            android:linksClickable="true"
            android:textColor="@color/botblade_baby_blue"
            android:text="@string/apk_download_links" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Vault: project secrets"
            android:textColor="@color/botblade_hot_pink"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <TextView
            android:id="@+id/secrets_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/botblade_on_surface_muted"
            android:text="@string/secrets_loading" />

        <EditText
            android:id="@+id/secret_name_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/secret_name_hint"
            android:textColor="@color/botblade_on_surface"
            android:textColorHint="@color/botblade_on_surface_muted"
            android:inputType="textCapCharacters|textNoSuggestions" />

        <EditText
            android:id="@+id/secret_type_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/secret_type_hint"
            android:textColor="@color/botblade_on_surface"
            android:textColorHint="@color/botblade_on_surface_muted"
            android:inputType="textNoSuggestions" />

        <EditText
            android:id="@+id/secret_project_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/secret_project_hint"
            android:textColor="@color/botblade_on_surface"
            android:textColorHint="@color/botblade_on_surface_muted"
            android:inputType="textNoSuggestions" />

        <EditText
            android:id="@+id/secret_value_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/secret_value_hint"
            android:textColor="@color/botblade_on_surface"
            android:textColorHint="@color/botblade_on_surface_muted"
            android:inputType="textPassword|textNoSuggestions" />

        <Button
            android:id="@+id/create_secret_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/save_secret" />

        <LinearLayout
            android:id="@+id/secrets_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>