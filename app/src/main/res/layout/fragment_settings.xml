<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textAppearance="?attr/textAppearanceHeadlineMedium" />

        <TextView
            android:id="@+id/secrets_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/secrets_loading" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/create_secret"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <EditText
            android:id="@+id/secret_name_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/secret_name_hint"
            android:inputType="textCapCharacters|textNoSuggestions" />

        <EditText
            android:id="@+id/secret_type_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/secret_type_hint"
            android:inputType="textNoSuggestions" />

        <EditText
            android:id="@+id/secret_project_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/secret_project_hint"
            android:inputType="textNoSuggestions" />

        <EditText
            android:id="@+id/secret_value_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/secret_value_hint"
            android:inputType="textPassword|textNoSuggestions" />

        <Button
            android:id="@+id/create_secret_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/save_secret" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/secrets_title"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <LinearLayout
            android:id="@+id/secrets_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
