<?xml version="1.0" encoding="utf-8"?>
<com.princess.botblade.ui.common.WorkstationScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <com.princess.botblade.ui.common.WorkstationCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:accentColor="@color/botblade_hot_pink">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Operations"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:textColor="@color/botblade_baby_blue"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/deployments_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Build history, deployment targets, runtime logs, and a container-scoped terminal for the active bot."
                    android:textColor="@color/botblade_on_surface_muted" />
            </LinearLayout>
        </com.princess.botblade.ui.common.WorkstationCardView>

        <com.princess.botblade.ui.common.WorkstationCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:accentColor="@color/botblade_baby_blue">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Deployments + targets"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:textColor="@color/botblade_baby_blue"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/deployments_active_project"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="local_process ready • local_docker ready • GitHub workflow preview • remote runner staged"
                    android:textColor="@color/botblade_on_surface_muted" />

                <EditText
                    android:id="@+id/deployment_target_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/deployment_target_name_hint"
                    android:inputType="text"
                    android:textColor="@color/botblade_on_surface"
                    android:textColorHint="@color/botblade_on_surface_muted" />

                <EditText
                    android:id="@+id/deployment_target_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/deployment_target_type_hint"
                    android:inputType="text"
                    android:textColor="@color/botblade_on_surface"
                    android:textColorHint="@color/botblade_on_surface_muted" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/create_target_button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/create_deployment_target" />

                    <Button
                        android:id="@+id/deploy_latest_build_button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="@string/deploy_latest_build" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/refresh_deployments_button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/refresh_status" />

                    <Button
                        android:id="@+id/create_deployment_button"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="@string/start_build" />
                </LinearLayout>

                <Button
                    android:id="@+id/release_check_button"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Release Checklist" />
            </LinearLayout>
        </com.princess.botblade.ui.common.WorkstationCardView>

        <LinearLayout
            android:id="@+id/build_list_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical" />

        <com.princess.botblade.ui.common.WorkstationCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            app:accentColor="@color/botblade_baby_blue">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/runtime_terminal_title"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:textColor="@color/botblade_baby_blue"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/ops_terminal_scope"
                    android:textColor="@color/botblade_on_surface_muted"
                    android:textStyle="bold" />

                <androidx.core.widget.NestedScrollView
                    android:layout_width="match_parent"
                    android:layout_height="260dp"
                    android:layout_marginTop="16dp"
                    android:background="@color/botblade_ink"
                    android:fillViewport="true"
                    android:nestedScrollingEnabled="true"
                    android:scrollbars="vertical">

                    <TextView
                        android:id="@+id/build_logs_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:minHeight="260dp"
                        android:padding="12dp"
                        android:text="@string/ops_terminal_placeholder"
                        android:textColor="@color/botblade_on_surface"
                        android:textIsSelectable="true" />
                </androidx.core.widget.NestedScrollView>
            </LinearLayout>
        </com.princess.botblade.ui.common.WorkstationCardView>
    </LinearLayout>
</com.princess.botblade.ui.common.WorkstationScrollView>